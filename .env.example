# Frontend (Create React App) — copy to .env at the repo root
# Backend env vars live in backend/env-template.txt → backend/.env

# API base URL for web and native builds
REACT_APP_API_BASE_URL=http://localhost:5001/api

# iOS simulator / physical device on LAN — use your Mac's IP instead of localhost:
# REACT_APP_API_BASE_URL=http://192.168.1.100:5001/api

# Set to true only after google-services.json is configured for Android FCM
# REACT_APP_ENABLE_ANDROID_PUSH=true
