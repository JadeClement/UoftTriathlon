sendgrid.env

# Data files that should not be tracked
backend/data/gear.json
backend/data/team-profiles.json

# Upload directories that should not be tracked
backend/uploads/

# Env files / secret backups (never commit real secrets)
.env
*.env
*.env.*
.env.local
.env.backup
*.env.backup
*.env.bak
backend/.env
backend/.env.*
backend/.env.backup
# Allow committed templates (must come after the ignore rules above)
!.env.example
!backend/env-template.txt

# Keys / certificates
*.key
*.pem
*.p12

# Firebase (client + admin credentials — never commit)
google-services.json
*-firebase-adminsdk-*.json
backend/config/firebase-service-account.json

# Accidental secrets / exports
s3-upload-user_accessKeys.csv
*.csv

# Dependencies (never commit these)
node_modules/
backend/node_modules/

# Build outputs
build/
dist/

# Capacitor
.capacitor/
android/

# Logs and OS cruft
npm-debug.log*
*.log
.DS_Store
